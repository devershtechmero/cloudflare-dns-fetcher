{
  "name": "cloudflare-dns-fetcher-backend",
  "version": "1.0.0",
  "description": "Backend API for Cloudflare DNS Fetcher.",
  "main": "dist/server.js",
  "type": "module",
  "engines": {
    "node": ">=25.9.0",
    "npm": ">=11.12.1"
  },
  "scripts": {
    "build:frontend": "npm --prefix ../frontend run build",
    "dev": "npm run build:frontend && tsx watch src/server.ts",
    "build": "npm run build:frontend && tsc -p tsconfig.json",
    "start": "npm run build:frontend && node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
